{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Rippo",
  "version": "0.3.2",
  "identifier": "app.rippopotamus.desktop",
  "build": {
    "frontendDist": "../dist/renderer",
    "devUrl": "http://127.0.0.1:5174"
  },
  "app": {
    "windows": [
      {
        "title": "Rippo",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/bin": "bin"
    },
    "category": "Video",
    "macOS": {
      "dmg": {
        "background": "dmg/background.png",
        "windowSize": {
          "width": 660,
          "height": 420
        },
        "appPosition": {
          "x": 165,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 495,
          "y": 170
        }
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Hellodebasishsahu/Rippopotamus/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENFNjY4NzUyNERDODgwRUYKUldUdmdNaE5Vb2RtempJRHhhTG9HS2hWR3IwWkZGU0RhZHdyVlU1WVdGdXBOL1VSSyt4d0thYzIK"
    }
  }
}
