{
  "name": "@rippopotamus/desktop",
  "private": true,
  "version": "0.2.0",
  "description": "Rippopotamus desktop app",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1 --port 5174 --strictPort\" \"wait-on http://127.0.0.1:5174 && tauri dev\"",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "build:ui": "tsc -p tsconfig.json --noEmit && vite build",
    "package:tauri:mac": "tauri build --bundles app,dmg",
    "package:tauri:win": "tauri build --bundles nsis"
  },
  "dependencies": {
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "simple-icons": "^16.20.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "wait-on": "^9.0.5"
  }
}
