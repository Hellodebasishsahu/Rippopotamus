{
  "name": "@rippopotamus/desktop",
  "private": true,
  "version": "0.2.0",
  "description": "Rippopotamus desktop app",
  "type": "commonjs",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.electron.json && concurrently -k \"vite --host 127.0.0.1 --port 5174 --strictPort\" \"wait-on http://127.0.0.1:5174 && VITE_DEV_SERVER_URL=http://127.0.0.1:5174 electron .\"",
    "build": "tsc -p tsconfig.json --noEmit && vite build && tsc -p tsconfig.electron.json",
    "build:ui": "tsc -p tsconfig.json --noEmit && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "package:mac": "electron-builder --mac dmg",
    "package:win": "electron-builder --win dir nsis --x64",
    "package:tauri:mac": "tauri build --bundles app,dmg",
    "package:tauri:win": "tauri build --bundles nsis"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.17.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "aria2": "^5.0.0",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "simple-icons": "^16.20.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "41.5.1",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "app.rippopotamus.desktop",
    "productName": "Rippopotamus",
    "asar": true,
    "afterPack": "../../scripts/after-pack.cjs",
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*"
    ],
    "files": [
      "dist/renderer/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../src/rippopotamus",
        "to": "engine/rippopotamus",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/*.pyo"
        ]
      },
      {
        "from": "../../pyproject.toml",
        "to": "engine/pyproject.toml"
      },
      {
        "from": "../../build/bin",
        "to": "bin"
      }
    ],
    "directories": {
      "output": "../../release"
    },
    "mac": {
      "icon": "public/brand-logo.png",
      "category": "public.app-category.video",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "public/brand-logo.ico",
      "target": [
        "dir",
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "artifactName": "Rippopotamus-Setup-${version}.exe"
    }
  }
}
