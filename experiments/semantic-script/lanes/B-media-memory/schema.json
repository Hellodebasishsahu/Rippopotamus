{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rippo.semantic-script.B-media-memory-v1",
  "title": "B Media Memory Moment Record",
  "type": "object",
  "required": ["asset_path", "source", "schema_version", "moments"],
  "properties": {
    "asset_path": { "type": "string" },
    "source": { "type": "string" },
    "schema_version": { "const": "B-media-memory-v1" },
    "chunk": {
      "type": "object",
      "properties": {
        "start": { "type": "number" },
        "end": { "type": "number" },
        "path": { "type": "string" }
      }
    },
    "moments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "start",
          "end",
          "summary",
          "visual",
          "audio",
          "visible_text",
          "actions",
          "objects",
          "people",
          "setting",
          "shot",
          "mood",
          "editor_use",
          "search_phrases",
          "confidence"
        ],
        "properties": {
          "start": { "type": "number" },
          "end": { "type": "number" },
          "summary": { "type": "string" },
          "visual": { "type": "string" },
          "audio": { "type": "string" },
          "visible_text": {
            "type": "array",
            "items": { "type": "string" }
          },
          "actions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "objects": {
            "type": "array",
            "items": { "type": "string" }
          },
          "people": {
            "type": "object",
            "required": ["count", "description"],
            "properties": {
              "count": { "type": "string" },
              "description": { "type": "string" }
            }
          },
          "setting": {
            "type": "array",
            "items": { "type": "string" }
          },
          "shot": {
            "type": "object",
            "required": ["type", "camera_motion", "composition"],
            "properties": {
              "type": { "type": "string" },
              "camera_motion": { "type": "string" },
              "composition": { "type": "string" }
            }
          },
          "mood": {
            "type": "array",
            "items": { "type": "string" }
          },
          "editor_use": {
            "type": "array",
            "items": { "type": "string" }
          },
          "search_phrases": {
            "type": "array",
            "items": { "type": "string" }
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    }
  }
}
